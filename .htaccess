# ──────────────────────────────────────────────
# Canonical: HTTPS + www
# Redirige HTTP a HTTPS y funesya.com.ar a www.funesya.com.ar
# (301 permanente para que Google consolide la autoridad de enlace)
# ──────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Excluir localhost y entornos de desarrollo
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1

    # HTTP → HTTPS
    # Se verifica también X-Forwarded-Proto porque el stack Docker/proxy termina
    # el TLS antes de llegar a Apache, por lo que %{HTTPS} siempre es "off".
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # funesya.com.ar → www.funesya.com.ar (dominio canónico)
    RewriteCond %{HTTP_HOST} ^funesya\.com\.ar$ [NC]
    RewriteRule ^ https://www.funesya.com.ar%{REQUEST_URI} [R=301,L]
</IfModule>

# ──────────────────────────────────────────────
# Seguridad: proteger archivos y directorios
# sensibles de acceso directo desde el navegador.
# ──────────────────────────────────────────────

# Bloquear acceso al archivo .env
<Files ".env">
    Require all denied
</Files>

# Bloquear acceso a cualquier archivo .sqlite/.db
<FilesMatch "\.(sqlite|sqlite3|db)$">
    Require all denied
</FilesMatch>

# Bloquear acceso a archivos de lock
<FilesMatch "\.lock$">
    Require all denied
</FilesMatch>

# Bloquear listado de directorios
Options -Indexes

# ──────────────────────────────────────────────
# Headers de seguridad HTTP globales
# ──────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # CSP: 'unsafe-inline' en script-src es necesario para el código de Google Analytics
    # y los bloques JSON-LD (<script type="application/ld+json">).
    # 'unsafe-inline' en style-src es necesario por el bloque <style> en article.php.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https: data:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self';"
</IfModule>

# ──────────────────────────────────────────────
# Compresión Gzip (reduce ~70% el tamaño de HTML/CSS/JS/JSON)
# Impacto: FCP y TTI más bajos, menos bytes transferidos en cada request.
# ──────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ──────────────────────────────────────────────
# Caché del navegador para assets estáticos
# CSS/JS: 1 semana (con cache-busting via ?v= en index.php)
# Imágenes/fuentes: 1 mes (cambian raramente)
# Impacto directo en visitas recurrentes: 0 requests HTTP para assets ya descargados.
# ──────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 7 days"
    ExpiresByType application/javascript    "access plus 7 days"
    ExpiresByType image/jpeg                "access plus 30 days"
    ExpiresByType image/png                 "access plus 30 days"
    ExpiresByType image/gif                 "access plus 30 days"
    ExpiresByType image/webp                "access plus 30 days"
    ExpiresByType image/svg+xml             "access plus 30 days"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
</IfModule>

# Eliminar ETags de archivos estáticos (los Expires son suficientes y evitan
# la negociación de caché innecesaria en Apache multi-servidor)
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|ico|woff|woff2)$">
        Header unset ETag
        FileETag None
    </FilesMatch>
</IfModule>
